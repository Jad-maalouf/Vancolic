# Supabase Postgres pooled connection string (Session/Transaction pooler, port 6543).
# Get this from: Supabase project -> Project Settings -> Database -> Connection string -> "Transaction" mode.
DATABASE_URL=postgresql://postgres.xxxxxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Any long random string, used to sign login JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Used only by scripts/seed.js to create the first manager login.
SEED_MANAGER_EMAIL=manager@vancolic.com
SEED_MANAGER_PASSWORD=change-me
SEED_MANAGER_NAME=Manager
